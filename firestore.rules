rules_version = '2';

/**
 * Regras de acesso do Firestore — PueriCare.
 *
 * Papéis (users/{uid}.role): ADMIN, PROFESSIONAL, CAREGIVER.
 * Por padrão, tudo é negado — cada coleção precisa de uma regra explícita.
 *
 * Bootstrap do primeiro ADMIN: não é possível criar um usuário com role
 * ADMIN pelo cliente (rota /setup ou SDK direto). O primeiro admin deve ser
 * criado manualmente no console do Firebase (Firestore > users/{uid} > role).
 */
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserDoc().role == role;
    }

    function isAdmin() {
      return hasRole('ADMIN');
    }

    function isProfessional() {
      return hasRole('PROFESSIONAL');
    }

    /* ── users/{userId} ── */
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // Autocadastro: só o próprio usuário cria seu documento, nunca como ADMIN.
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && request.resource.data.role in ['PROFESSIONAL', 'CAREGIVER']
        && request.resource.data.active == true;

      // Dono pode atualizar seus dados, mas não o próprio papel nem o status ativo.
      // ADMIN pode alterar qualquer campo (ex.: promover, bloquear conta).
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          request.auth.uid == userId &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.active == resource.data.active
        )
      );

      allow delete: if isAdmin();
    }

    /* ── children/{childId} ── */
    match /children/{childId} {
      allow read: if isSignedIn() && (
        resource.data.professionalId == request.auth.uid ||
        request.auth.uid in resource.data.caregiverIds ||
        isAdmin()
      );

      // Só profissionais criam crianças, e sempre vinculadas a si mesmos.
      allow create: if isProfessional()
        && request.resource.data.professionalId == request.auth.uid;

      // Só o profissional dono (ou admin) atualiza; professionalId é imutável.
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          resource.data.professionalId == request.auth.uid &&
          request.resource.data.professionalId == resource.data.professionalId
        )
      );

      allow delete: if isAdmin();
    }

    // Nega tudo que não tiver regra explícita acima (fecha o "modo de teste").
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
