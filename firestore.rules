rules_version = '2';

/**
 * Regras de acesso do Firestore — PueriCare.
 *
 * Papéis (users/{uid}.role): ADMIN, PROFESSIONAL, CAREGIVER.
 * Por padrão, tudo é negado — cada coleção precisa de uma regra explícita.
 *
 * Bootstrap do primeiro ADMIN: não é possível criar um usuário com role
 * ADMIN pelo cliente (rota /setup ou SDK direto). O primeiro admin deve ser
 * criado manualmente no console do Firebase (Firestore > users/{uid} > role).
 */
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    /**
     * Usuário autenticado COM CONTA ATIVA (users/{uid}.active == true).
     * Contas bloqueadas por um ADMIN (active == false) perdem todo acesso
     * aos dados — esta função é a base de todas as regras abaixo, então o
     * bloqueio vale também para chamadas diretas pelo SDK/API, não só na UI.
     */
    function isActiveUser() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserDoc().active == true;
    }

    function hasRole(role) {
      return isActiveUser() && currentUserDoc().role == role;
    }

    function isAdmin() {
      return hasRole('ADMIN');
    }

    function isProfessional() {
      return hasRole('PROFESSIONAL');
    }

    function childOf(childId) {
      return get(/databases/$(database)/documents/children/$(childId)).data;
    }

    /* ── users/{userId} ── */
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // Autocadastro: só o próprio usuário cria seu documento, nunca como ADMIN.
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && request.resource.data.role in ['PROFESSIONAL', 'CAREGIVER']
        && request.resource.data.active == true;

      // Dono pode atualizar seus dados, mas não o próprio papel nem o status ativo.
      // ADMIN pode alterar qualquer campo (ex.: promover, bloquear conta).
      // Conta bloqueada (active == false) não atualiza nem o próprio perfil.
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          isActiveUser() &&
          request.auth.uid == userId &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.active == resource.data.active
        )
      );

      allow delete: if isAdmin();
    }

    /* ── children/{childId} ── */
    match /children/{childId} {
      allow read: if isActiveUser() && (
        resource.data.professionalId == request.auth.uid ||
        request.auth.uid in resource.data.caregiverIds ||
        isAdmin()
      );

      // Só profissionais criam crianças, e sempre vinculadas a si mesmos.
      allow create: if isProfessional()
        && request.resource.data.professionalId == request.auth.uid;

      // Só o profissional dono (ou admin) atualiza; professionalId é imutável.
      allow update: if isActiveUser() && (
        isAdmin() ||
        (
          resource.data.professionalId == request.auth.uid &&
          request.resource.data.professionalId == resource.data.professionalId
        )
      );

      allow delete: if isAdmin();
    }

    /* ── consultations/{consultationId} ── Sprint 3 ── */
    match /consultations/{consultationId} {
      // Sem portal do responsável nesta fase (v2.0) — só o profissional dono e ADMIN leem.
      allow read: if isActiveUser() && (
        resource.data.professionalId == request.auth.uid || isAdmin()
      );

      // Só cria quem é PROFESSIONAL, dono da criança referenciada, e com a
      // criança ativa (não inicia consulta nova para paciente desativado).
      allow create: if isProfessional()
        && request.resource.data.professionalId == request.auth.uid
        && childOf(request.resource.data.childId).professionalId == request.auth.uid
        && childOf(request.resource.data.childId).active == true;

      // Só o profissional dono (ou admin) edita; childId e professionalId são imutáveis.
      allow update: if isActiveUser() && (
        isAdmin() ||
        (
          resource.data.professionalId == request.auth.uid &&
          request.resource.data.childId == resource.data.childId &&
          request.resource.data.professionalId == resource.data.professionalId
        )
      );

      allow delete: if isAdmin();
    }

    /* ── growthMeasurements/{measurementId} ── Sprint 4 ── */
    match /growthMeasurements/{measurementId} {
      // Mesma política de leitura de consultations: sem portal do responsável nesta fase.
      allow read: if isActiveUser() && (
        resource.data.professionalId == request.auth.uid || isAdmin()
      );

      // Mesma condição de consultations: PROFESSIONAL, dono da criança, criança ativa.
      allow create: if isProfessional()
        && request.resource.data.professionalId == request.auth.uid
        && childOf(request.resource.data.childId).professionalId == request.auth.uid
        && childOf(request.resource.data.childId).active == true;

      // Medições são imutáveis: nunca sobrescrever um registro já criado.
      // Sem "allow update" — nem o dono pode editar. Hard delete só ADMIN.
      allow delete: if isAdmin();
    }

    /* ── developmentAssessments/{assessmentId} ── Sprint 5 ── */
    match /developmentAssessments/{assessmentId} {
      // Mesma política de leitura de consultations/growthMeasurements.
      allow read: if isActiveUser() && (
        resource.data.professionalId == request.auth.uid || isAdmin()
      );

      // Mesma condição de growthMeasurements: PROFESSIONAL, dono da criança, criança ativa.
      allow create: if isProfessional()
        && request.resource.data.professionalId == request.auth.uid
        && childOf(request.resource.data.childId).professionalId == request.auth.uid
        && childOf(request.resource.data.childId).active == true;

      // Registros são imutáveis: nunca sobrescrever uma avaliação já criada.
      // Sem "allow update" — nem o dono pode editar. Hard delete só ADMIN.
      allow delete: if isAdmin();
    }

    /* ── feedingRecords/{recordId} ── Sprint 6 ── */
    match /feedingRecords/{recordId} {
      allow read: if isActiveUser() && (
        resource.data.professionalId == request.auth.uid || isAdmin()
      );
      allow create: if isProfessional()
        && request.resource.data.professionalId == request.auth.uid
        && childOf(request.resource.data.childId).professionalId == request.auth.uid
        && childOf(request.resource.data.childId).active == true;
      // Imutável: sem "allow update". Hard delete só ADMIN.
      allow delete: if isAdmin();
    }

    /* ── sleepRecords/{recordId} ── Sprint 6 ── */
    match /sleepRecords/{recordId} {
      allow read: if isActiveUser() && (
        resource.data.professionalId == request.auth.uid || isAdmin()
      );
      allow create: if isProfessional()
        && request.resource.data.professionalId == request.auth.uid
        && childOf(request.resource.data.childId).professionalId == request.auth.uid
        && childOf(request.resource.data.childId).active == true;
      // Imutável: sem "allow update". Hard delete só ADMIN.
      allow delete: if isAdmin();
    }

    /* ── vaccinationRecords/{recordId} ── Sprint 6 ── */
    match /vaccinationRecords/{recordId} {
      allow read: if isActiveUser() && (
        resource.data.professionalId == request.auth.uid || isAdmin()
      );
      allow create: if isProfessional()
        && request.resource.data.professionalId == request.auth.uid
        && childOf(request.resource.data.childId).professionalId == request.auth.uid
        && childOf(request.resource.data.childId).active == true;
      // Imutável: sem "allow update". Hard delete só ADMIN.
      allow delete: if isAdmin();
    }

    /* ── clinicalAlerts/{alertId} ── Sprint 7 ── */
    match /clinicalAlerts/{alertId} {
      // O profissional pode ler alertas vinculados a ele. Administradores podem ler tudo.
      allow read: if isActiveUser() && (
        resource.data.professionalId == request.auth.uid || isAdmin()
      );
      
      // Criar/atualizar alertas: Só profissional e admin.
      allow create, update: if isActiveUser() && (
        isAdmin() ||
        (
          request.resource.data.professionalId == request.auth.uid
        )
      );

      allow delete: if isAdmin();
    }

    /* ── reports/{reportId} ── Sprint B.4 ── */
    match /reports/{reportId} {
      // Sem portal do responsável nesta fase — só o profissional dono e ADMIN leem.
      allow read: if isActiveUser() && (
        resource.data.professionalId == request.auth.uid || isAdmin()
      );

      // Só cria como DRAFT (version 0), para paciente próprio e ativo.
      // Emissão é sempre uma transição por "update" (ver abaixo), nunca um create direto como ISSUED.
      allow create: if isProfessional()
        && request.resource.data.professionalId == request.auth.uid
        && request.resource.data.status == 'DRAFT'
        && request.resource.data.version == 0
        && childOf(request.resource.data.childId).professionalId == request.auth.uid
        && childOf(request.resource.data.childId).active == true;

      // Duas transições possíveis, sempre a partir de um DRAFT próprio:
      // 1) salvar rascunho (continua DRAFT, version não muda);
      // 2) emitir (DRAFT -> ISSUED, version passa a > 0, issuedBy = uid autenticado).
      // childId/professionalId são imutáveis. Um relatório ISSUED nunca é
      // atualizado por ninguém (a condição `resource.data.status == 'DRAFT'`
      // abaixo bloqueia isso incondicionalmente, inclusive para ADMIN).
      allow update: if isActiveUser()
        && resource.data.status == 'DRAFT'
        && resource.data.professionalId == request.auth.uid
        && request.resource.data.professionalId == resource.data.professionalId
        && request.resource.data.childId == resource.data.childId
        && (
          (request.resource.data.status == 'DRAFT' && request.resource.data.version == resource.data.version)
          ||
          (request.resource.data.status == 'ISSUED'
            && request.resource.data.version > 0
            && request.resource.data.issuedBy == request.auth.uid
            && request.resource.data.title is string
            && request.resource.data.title.size() > 0)
        );

      // DRAFT: autor pode excluir o próprio rascunho. ISSUED: nunca (nem o autor) — só ADMIN, mesma política das demais coleções clínicas.
      allow delete: if isAdmin() || (
        isActiveUser() && resource.data.status == 'DRAFT' && resource.data.professionalId == request.auth.uid
      );
    }

    /* ── reportCounters/{childId} ── Sprint B.4 ──
     * Contador interno (um documento por criança) usado só para atribuir a
     * próxima versão de relatório de forma atômica (via transaction no
     * service). Não é lido pela UI diretamente. */
    match /reportCounters/{childId} {
      allow read: if isActiveUser() && (
        childOf(childId).professionalId == request.auth.uid || isAdmin()
      );
      allow write: if isProfessional() && childOf(childId).professionalId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Nega tudo que não tiver regra explícita acima (fecha o "modo de teste").
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
